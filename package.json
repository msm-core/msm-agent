{
  "name": "msm-agent",
  "version": "0.1.0",
  "description": "Portable agent framework — brain-agnostic execution core for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bridge/msm": {
      "types": "./dist/bridge/msm.d.ts",
      "default": "./dist/bridge/msm.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx src/demo.ts",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "msm",
    "agent",
    "ai",
    "pipeline",
    "small-models",
    "multi-agent"
  ],
  "author": "Emad Jumaah",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/msm-core/msm-agent"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "tsx": "^4.19.4"
  }
}